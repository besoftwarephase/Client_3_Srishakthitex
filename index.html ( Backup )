}
.trust-card::after{content:"";position:absolute;left:0;top:0;height:3px;width:0;background:linear-gradient(90deg,var(--green),var(--lime));transition:width .4s var(--ease)}
.trust-card:hover{transform:translateY(-6px);box-shadow:var(--sh-md);border-color:transparent}
.trust-card:hover::after{width:100%}
.trust-ic{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:var(--navy-50);color:var(--navy);margin-bottom:18px;border:1px solid var(--gray-100)}
.trust-ic i{width:22px;height:22px}
.trust-ic svg{stroke-width:1.75}
.trust-card h3{font-size:17px;font-weight:600;margin-bottom:8px;color:var(--t-sub)}
.trust-card p{font-size:14px;color:var(--t-mut);line-height:1.55}

/* ============================================================
   PRODUCTS
   ============================================================ */
#products{background:var(--white)}
.prod-top{display:flex;justify-content:space-between;align-items:flex-end;gap:24px;flex-wrap:wrap;margin-bottom:30px}
.search-box{position:relative;min-width:260px}
.search-box i{position:absolute;left:16px;top:50%;transform:translateY(-50%);width:18px;height:18px;color:var(--t-mut)}
.search-box input{
  width:100%;height:48px;padding:0 18px 0 44px;border:1.5px solid var(--gray-100);
  border-radius:var(--r-pill);font-size:14px;color:var(--t-body);background:var(--gray-50);transition:border-color .2s,background .2s;
}
.search-box input:focus{outline:none;border-color:var(--teal);background:#fff}
.filters{display:flex;gap:8px;flex-wrap:wrap}
.filter-tab{
  padding:8px 16px;border-radius:var(--r-pill);font-size:13.5px;font-weight:500;
  background:var(--white);color:var(--t-body);border:1.5px solid var(--gray-100);
  transition:all .2s var(--ease);min-height:38px;
}
.filter-tab:hover{border-color:var(--navy-200);color:var(--t-head)}
.filter-tab.active{background:var(--navy);color:#fff;border-color:var(--navy)}

.prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.pcard{
  background:var(--white);border:1px solid var(--gray-100);border-radius:var(--r-lg);overflow:hidden;
  display:flex;flex-direction:column;transition:transform .3s var(--ease),box-shadow .3s var(--ease);position:relative;
}
.pcard:hover{transform:translateY(-7px);box-shadow:var(--sh-md)}
.pthumb{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--navy-50)}
.pthumb img{width:100%;height:100%;object-fit:cover;transition:transform .6s var(--ease)}
.pcard:hover .pthumb img{transform:scale(1.07)}
.pthumb-fallback{display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--navy-50),#d4e0ee)}
.pthumb-fallback i{width:46px;height:46px;color:var(--navy-200)}
.pcat-badge{
  position:absolute;top:12px;left:12px;background:var(--lime);color:var(--navy);
  font-size:11px;font-weight:700;padding:5px 11px;border-radius:var(--r-pill);letter-spacing:.02em;
}
.pdisc-badge{position:absolute;top:12px;left:12px;background:var(--coral);color:#fff;font-size:11px;font-weight:700;padding:5px 10px;border-radius:var(--r-pill)}
.pwish{
  position:absolute;top:10px;right:10px;width:38px;height:38px;border-radius:50%;
  background:rgba(255,255,255,.92);color:var(--t-mut);display:flex;align-items:center;justify-content:center;
  transition:all .25s;backdrop-filter:blur(4px);
}
.pwish:hover{transform:scale(1.1)}
.pwish i{width:19px;height:19px}
.pwish.on{color:var(--coral)}
.pwish.on i{fill:var(--coral)}
.pquick{
  position:absolute;left:12px;right:12px;bottom:12px;
  background:rgba(13,43,78,.92);color:#fff;border-radius:var(--r-pill);min-height:40px;
  display:flex;align-items:center;justify-content:center;gap:7px;font-size:13px;font-weight:600;
  opacity:0;transform:translateY(8px);transition:all .3s var(--ease);backdrop-filter:blur(4px);
}
.pquick i{width:16px;height:16px}
.pcard:hover .pquick{opacity:1;transform:translateY(0)}
.pbody{padding:16px;display:flex;flex-direction:column;flex:1;gap:8px}
.pbody h3{font-size:16px;font-weight:600;color:var(--t-sub);line-height:1.25;font-family:'Inter'}
.pspec{font-size:12.5px;color:var(--t-mut);display:flex;flex-wrap:wrap;gap:4px 10px}
.pspec span{display:inline-flex;align-items:center;gap:4px}
.pspec i{width:13px;height:13px;color:var(--green-700)}
.prating{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--t-mut)}
.prating .g-rate{font-weight:700;color:#202124;font-size:13.5px;font-variant-numeric:tabular-nums;font-family:Arial,'Inter',sans-serif}
.g-stars{position:relative;display:inline-block;width:84px;height:16px;line-height:0;vertical-align:middle}
.g-base,.g-fill{position:absolute;left:0;top:0;height:16px;overflow:hidden}
.g-base{width:100%}
.g-fill{width:0}
.g-base svg,.g-fill svg{display:block;width:84px;height:16px}
.pprice{margin-top:auto;display:flex;align-items:baseline;gap:8px;padding-top:6px}
.pprice .now{font-family:'Fraunces';font-weight:700;font-size:20px;color:var(--t-head)}
.pprice .from{font-size:12px;color:var(--t-mut);font-weight:500}
.pprice .mrp{font-size:13px;color:var(--t-dis);text-decoration:line-through}
.pprice .enq{font-family:'Inter';font-weight:600;font-size:15px;color:var(--green-700)}
.padd{margin-top:4px}
.empty-state{grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--t-mut)}
.empty-state i{width:48px;height:48px;color:var(--navy-200);margin:0 auto 16px}
.empty-state h3{font-size:22px;color:var(--t-sub);margin-bottom:8px;font-weight:600}

/* skeleton */
.skel{background:var(--white);border:1px solid var(--gray-100);border-radius:var(--r-lg);overflow:hidden;height:340px}
.skel .sk{background:linear-gradient(90deg,#eef1f4 25%,#f6f8fa 50%,#eef1f4 75%);background-size:200% 100%;animation:shimmer 1.3s infinite}
.skel .sk1{height:62%}
.skel .sk2{height:14px;margin:16px;border-radius:4px}
.skel .sk3{height:14px;margin:0 16px;width:60%;border-radius:4px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* ============================================================
   THREAD-COUNT SWITCHER  (SIGNATURE)
   ============================================================ */
#threads{background:var(--navy);color:#fff;position:relative;overflow:hidden}
#threads::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 80% 10%,rgba(139,195,74,.16),transparent 50%);pointer-events:none}
.tc-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:48px;align-items:center;position:relative;z-index:2}
.tc-switch{display:flex;flex-direction:column;gap:10px}
.tc-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px}
.tc-tab{
  flex:1;min-width:72px;min-height:64px;border-radius:var(--r-md);border:1.5px solid rgba(255,255,255,.16);
  background:rgba(255,255,255,.05);color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;
  transition:all .25s var(--ease);
}
.tc-tab b{font-family:'Fraunces';font-weight:700;font-size:22px;line-height:1}
.tc-tab span{font-size:10px;color:var(--navy-200);letter-spacing:.08em;text-transform:uppercase}
.tc-tab:hover{border-color:var(--lime)}
.tc-tab.active{background:var(--green);border-color:var(--green);box-shadow:0 14px 30px -14px rgba(76,175,80,.7)}
.tc-tab.active span{color:rgba(255,255,255,.85)}
.weave-toggle{display:flex;gap:8px;margin-top:6px}
.weave-toggle button{
  flex:1;min-height:42px;border-radius:var(--r-pill);border:1.5px solid rgba(255,255,255,.18);
  color:var(--navy-100);font-size:13px;font-weight:600;transition:all .22s;
}
.weave-toggle button.active{background:var(--yellow);color:var(--navy);border-color:var(--yellow)}
.tc-info{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--r-lg);padding:24px;margin-top:14px}
.tc-info h3{color:#fff;font-size:22px;font-weight:600;margin-bottom:6px}
.tc-info .chip{display:inline-block;background:rgba(139,195,74,.18);color:var(--lime);font-size:11px;font-weight:700;padding:4px 10px;border-radius:var(--r-pill);margin-bottom:12px;letter-spacing:.04em}
.tc-info p{color:var(--navy-100);font-size:14.5px;line-height:1.6}
.tc-info .tc-from{margin-top:14px;font-size:13px;color:var(--navy-200)}
.tc-info .tc-from b{font-family:'Fraunces';color:var(--lime);font-size:22px}

.tc-visual{position:relative;border-radius:var(--r-xl);overflow:hidden;box-shadow:var(--sh-lg);aspect-ratio:1/1;background:var(--navy-900)}
.tc-visual img{width:100%;height:100%;object-fit:cover;transition:opacity .5s var(--ease)}
.weave-svg{position:absolute;inset:0;width:100%;height:100%;mix-blend-mode:soft-light;opacity:.9;pointer-events:none}
.tc-density{position:absolute;left:18px;bottom:18px;background:rgba(9,30,54,.78);color:#fff;border-radius:var(--r-md);padding:12px 16px;backdrop-filter:blur(6px)}
.tc-density .dn{font-family:'Fraunces';font-weight:700;font-size:24px;color:var(--lime);line-height:1}
.tc-density .dl{font-size:11px;color:var(--navy-100);letter-spacing:.1em;text-transform:uppercase;margin-top:3px}

/* ============================================================
   SERVICES / WHY CHOOSE US (accordion)
   ============================================================ */
#why{background:var(--gray-50)}
.why-grid{max-width:820px;margin:0 auto}
.acc-item{border-bottom:1px solid var(--gray-100);overflow:hidden}
.acc-head{
  width:100%;display:flex;align-items:center;gap:16px;padding:22px 4px;text-align:left;
  transition:color .2s;
}
.acc-num{font-family:'Fraunces';font-weight:700;font-size:15px;color:var(--green-700);min-width:24px}
.acc-title{flex:1;font-family:'Fraunces';font-size:20px;font-weight:600;color:var(--t-sub);transition:color .2s}
.acc-head:hover .acc-title{color:var(--green-700)}
.acc-chev{width:34px;height:34px;border-radius:50%;background:var(--white);border:1px solid var(--gray-100);display:flex;align-items:center;justify-content:center;color:var(--navy);transition:transform .35s var(--ease),background .25s}
.acc-chev i{width:18px;height:18px}
.acc-item.active .acc-chev{transform:rotate(180deg);background:var(--green);color:#fff;border-color:var(--green)}
.acc-item.active .acc-title{color:var(--navy)}
.acc-body{max-height:0;overflow:hidden;transition:max-height .4s var(--ease)}
.acc-body-inner{padding:0 4px 24px 44px;color:var(--t-mut);font-size:15px;line-height:1.65}
.why-tag{display:inline-block;margin-top:14px;background:var(--navy-50);color:var(--navy);padding:6px 14px;border-radius:var(--r-pill);font-size:12.5px;font-weight:600;letter-spacing:.01em}

/* ============================================================
   ENQUIRY / BULK ORDER
   ============================================================ */
#enquiry{background:var(--white)}
.enq-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:40px;align-items:start}
.enq-cart{background:var(--gray-50);border:1px solid var(--gray-100);border-radius:var(--r-lg);padding:24px}
.enq-cart h3{font-size:20px;font-weight:600;margin-bottom:4px}
.enq-cart .sub{font-size:13px;color:var(--t-mut);margin-bottom:18px}
.etable{display:flex;flex-direction:column;gap:10px}
.erow{display:grid;grid-template-columns:54px 1fr auto auto;gap:12px;align-items:center;background:#fff;border:1px solid var(--gray-100);border-radius:var(--r-md);padding:10px}
.erow img{width:54px;height:54px;border-radius:10px;object-fit:cover;background:var(--navy-50)}
.erow .en{font-size:14px;font-weight:600;color:var(--t-sub);line-height:1.2}
.erow .es{font-size:12px;color:var(--t-mut)}
.qty-step{display:flex;align-items:center;gap:2px;border:1px solid var(--gray-100);border-radius:var(--r-pill);padding:2px}
.qty-step button{width:30px;height:30px;border-radius:50%;color:var(--navy);font-size:18px;font-weight:600;display:flex;align-items:center;justify-content:center;transition:background .2s}
.qty-step button:hover{background:var(--navy-50)}
.qty-step input{width:34px;text-align:center;border:none;background:none;font-size:14px;font-weight:600;color:var(--t-head);font-variant-numeric:tabular-nums}
.erow .erm{width:34px;height:34px;border-radius:50%;color:var(--coral);display:flex;align-items:center;justify-content:center;transition:background .2s}
.erow .erm:hover{background:rgba(244,123,92,.12)}
.erow .erm i{width:17px;height:17px}
.enq-empty{text-align:center;padding:34px 16px;color:var(--t-mut);font-size:14px}
.enq-empty i{width:40px;height:40px;color:var(--navy-200);margin:0 auto 12px}

.enq-form{background:var(--navy);color:#fff;border-radius:var(--r-lg);padding:28px}
.enq-form h3{color:#fff;font-size:22px;font-weight:600;margin-bottom:4px}
.enq-form .fsub{color:var(--navy-100);font-size:14px;margin-bottom:20px}
.field{margin-bottom:14px}
.field label{display:block;font-size:12px;font-weight:600;color:var(--navy-100);margin-bottom:6px;letter-spacing:.02em}
.field input,.field select,.field textarea{
  width:100%;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.16);border-radius:var(--r-sm);
  padding:12px 14px;color:#fff;font-size:14px;font-family:'Inter';transition:border-color .2s,background .2s;min-height:46px;
}
.field textarea{min-height:90px;resize:vertical}
.field input::placeholder,.field textarea::placeholder{color:var(--navy-200)}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--lime);background:rgba(255,255,255,.12)}
.field select option{color:var(--navy);background:#fff}
.field.err input,.field.err select{border-color:var(--coral)}
.field .emsg{font-size:11.5px;color:var(--coral);margin-top:4px;display:none}
.field.err .emsg{display:block}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.enq-actions{display:flex;gap:10px;margin-top:8px;flex-wrap:wrap}
.enq-actions .btn{flex:1;min-width:150px}

/* ============================================================
   ABOUT
   ============================================================ */
#about{background:var(--gray-50)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
.about-copy h2{font-size:clamp(28px,4vw,42px);font-weight:700;line-height:1.12;margin:14px 0 18px}
.about-copy p{color:var(--t-body);font-size:15.5px;margin-bottom:14px;line-height:1.7}
.mission{background:var(--white);border-left:3px solid var(--green);border-radius:0 var(--r-md) var(--r-md) 0;padding:18px 22px;margin:22px 0;font-family:'Fraunces';font-style:italic;font-size:18px;color:var(--t-sub);line-height:1.5}
.about-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.stat-card{background:var(--white);border:1px solid var(--gray-100);border-radius:var(--r-md);padding:22px}
.stat-card .num{font-family:'Fraunces';font-weight:700;font-size:30px;color:var(--green-700);line-height:1}
.stat-card .lbl{font-size:13px;color:var(--t-mut);margin-top:6px}
.about-media{position:relative;min-height:clamp(420px,52vw,560px)}
.about-media .am-main{width:74%;margin-left:auto;border-radius:var(--r-xl);overflow:hidden;box-shadow:var(--sh-md);aspect-ratio:4/5}
.about-media .am-main img{width:100%;height:100%;object-fit:cover;display:block}
.about-media .am-float{position:absolute;border-radius:var(--r-md);overflow:hidden;box-shadow:var(--sh-lg);border:4px solid #fff;will-change:transform}
.about-media .am-float img{width:100%;height:100%;object-fit:cover;display:block}
.about-media .am-f1{width:42%;aspect-ratio:1/1;top:-18px;right:-14px;animation:amFloat 6s var(--ease) infinite}
.about-media .am-f2{width:40%;aspect-ratio:1/1;bottom:54px;left:-18px;animation:amFloat 7.2s var(--ease) infinite .7s}
.about-media .am-f3{width:36%;aspect-ratio:4/3;bottom:-14px;right:12%;animation:amFloat 6.6s var(--ease) infinite .35s}
@keyframes amFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
@media(prefers-reduced-motion:reduce){.about-media .am-float{animation:none}}

/* ============================================================
   TESTIMONIALS
   ============================================================ */
#reviews{background:var(--white);position:relative;overflow:hidden}
#reviews .sec-head h2{color:var(--t-head)}
#reviews .sec-head p{color:var(--t-mut)}
.featured-quote{
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--r-xl);
  padding:42px;position:relative;margin-bottom:32px;position:relative;z-index:2;
}
.featured-quote .qmark{font-family:'Fraunces';font-size:90px;font-weight:900;color:var(--lime);line-height:.6;position:absolute;top:26px;left:34px;opacity:.5}
.featured-quote blockquote{font-family:'Fraunces';font-style:italic;font-size:clamp(20px,2.6vw,28px);line-height:1.45;color:#fff;position:relative;z-index:2;padding-left:8px}
.featured-quote .qby{display:flex;align-items:center;gap:14px;margin-top:26px}
.featured-quote .qav{width:52px;height:52px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;font-family:'Fraunces';font-weight:700;font-size:22px;color:#fff}
.featured-quote .qn{font-weight:700;color:#fff;font-size:16px}
.featured-quote .qm{font-size:13px;color:var(--navy-100)}
.featured-quote .qbadge{display:inline-flex;align-items:center;gap:5px;background:rgba(139,195,74,.16);color:var(--lime);font-size:11px;font-weight:700;padding:4px 10px;border-radius:var(--r-pill);margin-left:auto}
.featured-quote .qbadge i{width:13px;height:13px}
.rev-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;position:relative;z-index:2}
.rev-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--r-lg);padding:22px;transition:transform .3s var(--ease),background .3s}
.rev-card:hover{transform:translateY(-5px);background:rgba(255,255,255,.08)}
.rev-card .stars{color:var(--yellow);display:flex;gap:1px;margin-bottom:12px}
.rev-card .stars i{width:15px;height:15px;fill:var(--yellow)}
.rev-card p{font-size:14px;color:var(--navy-100);line-height:1.55;margin-bottom:16px}
.rev-card .rn{font-size:13px;font-weight:600;color:#fff}
.rev-card .rm{font-size:12px;color:var(--navy-200)}

/* ============================================================
   NEWSLETTER
   ============================================================ */
#newsletter{background:var(--white)}
.nl-band{text-align:center;max-width:760px;margin:0 auto;background:var(--navy);color:#fff;border-radius:var(--r-xl);padding:clamp(36px,5vw,56px) clamp(24px,4vw,48px)}
.nl-band h2{color:#fff;font-size:clamp(24px,3.2vw,34px);font-weight:700;line-height:1.14;margin-bottom:10px}
.nl-band p{color:var(--navy-100);font-size:15.5px;margin-bottom:26px}
.nl-form{display:flex;gap:10px;max-width:480px;margin:0 auto;background:#fff;padding:7px;border-radius:var(--r-pill);box-shadow:var(--sh-sm)}
.nl-form input{flex:1;border:none;background:none;padding:0 18px;font-size:15px;color:var(--t-body);min-height:46px}
.nl-form input:focus{outline:none}
.nl-note{font-size:12.5px;color:var(--navy-100);margin-top:14px}
.nl-success{display:none;align-items:center;justify-content:center;gap:10px;max-width:480px;margin:0 auto;background:#fff;border-radius:var(--r-pill);padding:16px 24px;color:var(--green-700);font-weight:600;font-size:15px}
.nl-success i{width:22px;height:22px}
.nl-success.show{display:flex}

/* ============================================================
   FOOTER
   ============================================================ */
footer{background:var(--navy-900);color:var(--navy-100)}
.foot-main{padding:66px 0 0}
.foot-grid{display:grid;grid-template-columns:1.7fr 1fr 1fr 1fr;gap:48px;padding-bottom:100px}
.foot-id{display:flex;align-items:center;gap:12px;margin-bottom:18px}
.foot-logo{width:42px;height:42px;flex-srink:0;display:block}
.foot-logo svg{width:100%;height:100%}
.foot-brand .fb-name{font-family:'Fraunces';font-weight:700;font-size:21px;color:#fff;line-height:1.1;display:flex;flex-direction:column}
.foot-brand .fb-name span{color:var(--lime);font-size:11px;font-weight:500;font-family:'Inter';letter-spacing:.06em;margin-top:3px}
.foot-brand .fb-tag{font-size:13.5px;color:var(--navy-200);margin:0 0 30px;line-height:1.65;max-width:300px}
.foot-brand .fb-contact{display:flex;flex-direction:column;gap:11px}
.foot-brand .fb-contact a{display:inline-flex;align-items:center;gap:10px;font-size:13.5px;color:var(--navy-100);transition:color .2s;word-break:break-word}
.foot-brand .fb-contact a:hover{color:var(--lime)}
.foot-brand .fb-contact a i{width:15px;height:15px;color:var(--lime);flex-srink:0}
