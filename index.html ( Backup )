.facet-sel select:focus{outline:none;border-color:var(--teal);box-shadow:0 0 0 4px rgba(27,108,168,.12)}
.facet-sel i{position:absolute;right:13px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--t-mut);pointer-events:none}
.facet-clear{display:inline-flex;align-items:center;gap:7px;height:40px;padding:0 16px;border-radius:var(--r-pill);border:1.5px solid transparent;background:none;color:var(--t-mut);font-size:13px;font-weight:600;cursor:pointer;transition:.2s var(--ease)}
.facet-clear:hover{color:var(--navy);background:var(--gray-50)}
.facet-clear i{width:15px;height:15px}

/* ---- Quick-view modal gallery ---- */
.modal-card{display:block!important;max-width:920px;padding:0}
.modal-grid{display:grid;grid-template-columns:1.04fr 1fr}
.modal-gallery{position:relative;background:var(--navy-50);padding:18px;display:flex;flex-direction:column;gap:12px}
.mg-main{position:relative;flex:1;border-radius:16px;overflow:hidden;background:#fff;min-height:340px;cursor:zoom-in}
.mg-main img{width:100%;height:100%;object-fit:cover;transition:transform .4s var(--ease)}
.mg-main.zoom img{transform:scale(2);cursor:zoom-out}
.mg-main .mbadge{position:absolute;top:14px;left:14px;background:var(--lime);color:var(--navy);font-size:11px;font-weight:700;padding:5px 12px;border-radius:var(--r-pill);z-index:2}
.mg-nav{position:absolute;top:50%;transform:translateY(-50%);width:38px;height:38px;border-radius:50%;border:none;background:rgba(255,255,255,.92);color:var(--navy);display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 6px 16px -8px rgba(9,30,54,.5);transition:.2s;z-index:2}
.mg-nav:hover{background:#fff;transform:translateY(-50%) scale(1.08)}
.mg-nav.prev{left:12px}.mg-nav.next{right:12px}.mg-nav i{width:18px;height:18px}
.mg-hint{position:absolute;bottom:12px;right:12px;background:rgba(9,30,54,.72);color:#fff;font-size:11px;padding:5px 11px;border-radius:var(--r-pill);display:flex;align-items:center;gap:5px;z-index:2}.mg-hint i{width:13px;height:13px}
.mg-thumbs{display:flex;gap:9px}
.mg-thumbs img{width:60px;height:60px;object-fit:cover;border-radius:10px;cursor:pointer;border:2px solid transparent;opacity:.6;transition:.2s}
