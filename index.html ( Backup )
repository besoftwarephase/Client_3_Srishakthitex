@media(max-width:680px){.erow img{ width: 45px;height: 45px;}.erow {gap: 5px;}.hs-arrow{ display: none;}.hs-arrow{width:42px;height:42px}.hs-arrow.prev{left:12px}.hs-arrow.next{right:12px}.hs-arrow i{width:20px;height:20px} .brand-text {display: none;}}
