function closeMenu(){ const m=document.getElementById('mobile-menu'); if(m.classList.contains('open')) toggleMenu(); }

function initHeaderGlass(){
  const sentinel=document.createElement('div'); sentinel.style.cssText='position:absolute;top:0;height:80px;width:1px;pointer-events:none';
  document.getElementById('hero').appendChild(sentinel);
  new IntersectionObserver(([e])=>{
    document.getElementById('header').classList.toggle('glass', !e.isIntersecting);
  },{threshold:0}).observe(sentinel);
}
function initReveal(){
  const io=new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  },{threshold:0.12, rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
}
function initNavSpy(){
  const ids=['hero','about','products','reviews','enquiry'];
  const map={hero:'Home',about:'About',products:'Products',reviews:'Reviews',enquiry:'Contact'};
  const io=new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){
      document.querySelectorAll('#navlinks a').forEach(a=>a.classList.toggle('active', a.getAttribute('href')==='#'+e.target.id));
    }});
  },{threshold:0.4});
  ids.forEach(id=>{const el=document.getElementById(id); if(el)io.observe(el);});
}

/* ============================================================
   INIT
   ============================================================ */
function init(){
  loadState();
  const rb=document.getElementById('rb-stars'); if(rb) rb.innerHTML=starsHTML();
  buildHeroBg();
  buildSlideshow();
  buildMarquee();
  buildCats();
  buildFacets();
  renderProducts();
  buildThreadTabs(); setThread(0);
  buildWhy();
  buildReviews();
  renderEnquiry();
  updateBadges();
  initHeaderGlass();
  initReveal();
  initNavSpy();
  icons();
}
document.addEventListener('keydown',(e)=>{
  if(e.key==='Escape'){
    if(document.getElementById('modal').classList.contains('show')) closeModal();
    else if(document.getElementById('drawer').classList.contains('open')) closeDrawer();
    else if(document.getElementById('mobile-menu').classList.contains('open')) toggleMenu();
  }
});
window.addEventListener('load',()=>{
  init();
  setTimeout(()=>document.getElementById('loader').classList.add('done'),650);
});
</script>
