<base href="${location.href}">
<title>${p.name} — SriShakthi Tex</title>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--navy:#0D2B4E;--navy-900:#091E36;--teal:#1B6CA8;--green:#4CAF50;--green-700:#388E3C;--lime:#8BC34A;--yellow:#F5C842;--coral:#F47B5C;--g50:#F8F9FA;--g100:#E9ECEF;--ink:#091E36;--body:#343A40;--mut:#6C757D;--navy-100:#C5D5E8;--navy-200:#8AAECF;--ease:cubic-bezier(.22,.61,.36,1)}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',system-ui,sans-serif;color:var(--body);background:var(--g50);-webkit-font-smoothing:antialiased;line-height:1.6}
h1,h2,h3,h4{font-family:'Fraunces',Georgia,serif;color:var(--ink);letter-spacing:-.01em;line-height:1.1}
a{color:inherit}
.shell{max-width:1180px;margin:0 auto;padding:22px 22px 64px}
.topbar{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:22px;flex-wrap:wrap}
.back{display:inline-flex;align-items:center;gap:9px;color:var(--navy);font-weight:600;text-decoration:none;font-size:14px;padding:10px 18px;border:1.5px solid var(--g100);border-radius:40px;background:#fff;transition:.25s var(--ease)}
.back:hover{border-color:var(--teal);color:var(--teal);transform:translateX(-3px)}
.back svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.crumb{font-size:12px;color:var(--mut);letter-spacing:.04em;text-transform:uppercase;font-weight:600}
.crumb b{color:var(--green-700)}
.wishbtn{display:inline-flex;align-items:center;gap:9px;color:var(--mut);font-weight:600;font-size:13px;cursor:pointer;padding:11px 18px;border:1.5px solid var(--g100);border-radius:40px;background:#fff;transition:.25s var(--ease)}
.wishbtn svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.wishbtn.saved{border-color:var(--coral);color:var(--coral);background:#FDEEEA}.wishbtn.saved svg{fill:var(--coral)}
.card{background:#fff;border:1px solid var(--g100);border-radius:22px;box-shadow:0 20px 50px -34px rgba(13,43,78,.4)}
.hero{display:grid;grid-template-columns:1.05fr 1fr;gap:0;overflow:hidden}
.gallery{display:flex;gap:14px;padding:20px}
.thumbs{display:flex;flex-direction:column;gap:10px}
.thumbs img{width:58px;height:58px;object-fit:cover;border-radius:11px;cursor:pointer;border:2px solid transparent;opacity:.65;transition:.25s}
.thumbs img.active,.thumbs img:hover{opacity:1;border-color:var(--teal)}
.stage{position:relative;flex:1;border-radius:16px;overflow:hidden;background:var(--navy-50,#E8EEF5);min-height:420px;cursor:zoom-in}
.stage img{width:100%;height:100%;object-fit:cover;transition:transform .4s var(--ease)}
.stage.zoom img{transform:scale(2);cursor:zoom-out}
.stage .badge{position:absolute;top:16px;left:16px;background:var(--lime);color:var(--navy);font-size:11px;font-weight:700;padding:6px 13px;border-radius:40px;font-family:'Inter'}
.stage .hint{position:absolute;bottom:14px;right:14px;background:rgba(9,30,54,.7);color:#fff;font-size:11px;padding:5px 11px;border-radius:40px}
.info{padding:36px 34px;display:flex;flex-direction:column}
.kick{color:var(--green-700);font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px}
.ptitle{font-size:32px;font-weight:600;margin-bottom:12px}.ptitle em{font-style:normal;color:var(--green-700)}
.rating{display:flex;align-items:center;gap:8px;margin-bottom:16px;color:var(--mut);font-size:13px}.stars{display:inline-flex;gap:1px}.stars svg{width:16px;height:16px}
.price{display:flex;align-items:baseline;gap:12px;margin-bottom:16px}
.price .now{font-size:30px;font-weight:700;color:var(--ink);font-family:'Fraunces';font-variant-numeric:tabular-nums}
.price .was{color:var(--mut);text-decoration:line-through;font-size:17px}
.price .off{background:var(--coral);color:#fff;font-size:12px;font-weight:700;padding:3px 9px;border-radius:6px}
.price .enq{font-size:20px;font-weight:700;color:var(--teal)}
.desc{color:var(--body);font-size:14.5px;margin-bottom:22px}
.lbl{font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--mut);margin:0 0 10px}.lbl .sel-name{color:var(--ink);text-transform:none;letter-spacing:0;margin-left:6px}
.swatches{display:flex;gap:10px;margin-bottom:20px}
.sw{width:34px;height:34px;border-radius:50%;cursor:pointer;border:2px solid var(--g100);box-shadow:inset 0 0 0 2px #fff;transition:.2s}.sw.sel{border-color:var(--teal);transform:scale(1.08)}
.sw.pattern{border-radius:10px;background-size:cover;background-position:center;background-color:var(--g50);box-shadow:none}
.sizes{display:flex;flex-wrap:wrap;gap:9px;margin-bottom:22px}
.size{padding:9px 16px;border:1.5px solid var(--g100);border-radius:10px;cursor:pointer;font-size:13px;font-weight:600;color:var(--body);transition:.2s}.size.sel{border-color:var(--navy);background:var(--navy);color:#fff}
.buy{display:flex;gap:12px;align-items:stretch}
.qty{display:flex;align-items:center;border:1.5px solid var(--g100);border-radius:12px;overflow:hidden}
.qty button{width:42px;border:none;background:#fff;font-size:18px;cursor:pointer;color:var(--navy)}.qty span{width:54px;text-align:center;font-weight:700;font-variant-numeric:tabular-nums}
.btn{flex:1;border:none;border-radius:12px;font-family:'Inter';font-weight:600;font-size:15px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:9px;transition:.25s var(--ease)}
.btn-primary{background:var(--green-700);color:#fff;padding:13px}.btn-primary:hover{background:#2E7D32}
.btn-wa{background:var(--green);color:#fff;padding:13px;margin-top:12px;width:100%}.btn-wa:hover{background:var(--green-700)}
.btn svg{width:18px;height:18px}
.trust{display:flex;flex-wrap:wrap;gap:16px;margin-top:22px;padding-top:20px;border-top:1px solid var(--g100)}
.trust div{display:flex;align-items:center;gap:7px;font-size:12.5px;color:var(--mut);font-weight:600}.trust svg{width:16px;height:16px;stroke:var(--green-700);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.features{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:22px}
.feat{background:#fff;border:1px solid var(--g100);border-radius:16px;padding:22px}
.fic{width:42px;height:42px;border-radius:12px;background:rgba(76,175,80,.12);display:flex;align-items:center;justify-content:center;margin-bottom:12px}.fic svg{width:22px;height:22px;stroke:var(--green-700);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.feat h4{font-size:15px;margin-bottom:5px}.feat p{font-size:13px;color:var(--mut)}
.two{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px}
.sec{padding:28px}.sec h3{font-size:20px;margin-bottom:14px}
.checks{list-style:none;margin-top:6px}.checks li{display:flex;gap:10px;align-items:flex-start;padding:7px 0;font-size:14px;color:var(--body)}.checks svg{width:18px;height:18px;stroke:var(--green-700);fill:none;stroke-width:2.4;stroke-linecap:round;stroke-linejoin:round;flex-srink:0;margin-top:2px}
.dim{display:flex;justify-content:space-between;gap:12px;padding:11px 0;border-bottom:1px dashed var(--g100);font-size:13.5px}.dim span:first-child{color:var(--mut)}.dim .v{font-weight:600;color:var(--ink)}
.reviews{padding:28px;margin-top:18px}
.rev-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:14px}
.rev{background:var(--g50);border:1px solid var(--g100);border-radius:16px;padding:20px}
.rev .top{display:flex;align-items:center;gap:11px;margin-bottom:10px}.av{width:40px;height:40px;border-radius:50%;background:var(--navy);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-family:'Fraunces'}
.rev .nm{font-size:13.5px;font-weight:700;color:var(--ink)}.rev .vb{font-size:11px;color:var(--green-700);display:flex;align-items:center;gap:4px}.rev .vb svg{width:11px;height:11px}
.rev .rs{display:flex;margin:6px 0 8px}.rev .rs svg{width:14px;height:14px}.rev p{font-size:13.5px;color:var(--body)}.rev .when{font-size:11.5px;color:var(--mut);margin-top:8px}
.related{margin-top:30px}.related h3{font-size:24px;text-align:center;margin-bottom:18px}
/* horizontal scroller for "You May Also Like" */
.rel-wrap{position:relative}
.rel-grid{display:flex;gap:16px;overflow-x:auto;scroll-behavior:smooth;padding:6px 2px 14px;scroll-snap-type:x proximity;-ms-overflow-style:none;scrollbar-width:none}
.rel-grid::-webkit-scrollbar{display:none}
.rel{flex:0 0 200px;scroll-snap-align:start;background:#fff;border:1px solid var(--g100);border-radius:16px;overflow:hidden;cursor:pointer;transition:transform .3s var(--ease),box-shadow .3s var(--ease),border-color .3s var(--ease)}
.rel:hover{transform:translateY(-6px);box-shadow:0 20px 40px -24px rgba(13,43,78,.4);border-color:var(--navy-100)}
/* slide arrows */
.rel-arrow{position:absolute;top:calc(50% - 7px);transform:translateY(-50%);z-index:4;width:46px;height:46px;border-radius:50%;border:1px solid var(--g100);background:#fff;color:var(--navy);display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 14px 30px -14px rgba(9,30,54,.45);transition:opacity .3s var(--ease),transform .3s var(--ease),background .25s,color .25s,visibility .3s}
.rel-arrow:hover{background:var(--navy);color:#fff;border-color:var(--navy)}
.rel-arrow svg{width:22px;height:22px;stroke:currentColor;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}
.rel-arrow.prev{left:-8px}
.rel-arrow.next{right:-8px}
.rel-arrow.prev:hover{transform:translateY(-50%) translateX(-3px)}
.rel-arrow.next:hover{transform:translateY(-50%) translateX(3px)}
.rel-arrow[disabled]{opacity:0;visibility:hidden;pointer-events:none}
@media(max-width:560px){.rel{flex:0 0 60%}.rel-arrow{display:none}}
.rel .ri{height:130px;overflow:hidden;background:var(--g50)}.rel img{width:100%;height:100%;object-fit:cover;transition:.5s var(--ease)}.rel:hover img{transform:scale(1.07)}
.rel .b{padding:12px 14px}.rel .nm{font-size:13px;font-weight:600;color:var(--ink)}.rel .pr{font-size:13px;color:var(--green-700);font-weight:700;margin-top:3px;font-variant-numeric:tabular-nums}
footer{background:var(--navy-900);color:var(--navy-100);margin-top:46px;border-radius:24px;overflow:hidden}
.foot-in{max-width:1180px;margin:0 auto;padding:46px 30px 26px;display:grid;grid-template-columns:1.6fr 1fr 1.4fr;gap:34px}
.foot-in h4{color:#fff;font-size:13px;letter-spacing:.06em;text-transform:uppercase;margin-bottom:14px}
.foot-brand .fn{font-family:'Fraunces';font-size:22px;color:#fff;font-weight:600}.foot-brand .fn span{color:var(--lime);font-size:13px}
.foot-brand p{font-size:13.5px;margin:12px 0 16px;max-width:320px}
.foot-col a{display:block;color:var(--navy-100);text-decoration:none;font-size:13.5px;padding:5px 0;transition:.2s}.foot-col a:hover{color:var(--lime)}
.fcr{display:flex;gap:9px;font-size:13.5px;padding:5px 0;align-items:flex-start}.fcr svg{width:16px;height:16px;stroke:var(--lime);fill:none;stroke-width:1.8;flex-srink:0;margin-top:2px}
.fcr a{color:var(--navy-100);text-decoration:none}.fcr a:hover{color:var(--lime)}
.fgst{display:inline-block;margin-top:10px;font-size:11.5px;color:var(--lime);border:1px solid rgba(139,195,74,.3);padding:4px 10px;border-radius:40px}
.foot-soc{display:flex;gap:10px;margin-top:14px}
.foot-soc a{width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;transition:.25s}.foot-soc a:hover{background:var(--lime)}.foot-soc svg{width:17px;height:17px;stroke:#fff;fill:none;stroke-width:1.8}.foot-soc a:hover svg{stroke:var(--navy)}
.foot-bot{border-top:1px solid rgba(255,255,255,.08);padding:18px 30px;text-align:center;font-size:12.5px;color:var(--navy-200);max-width:1180px;margin:0 auto}
.toast{position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(150%);background:var(--navy);color:#fff;padding:14px 26px;border-radius:40px;font-size:14px;font-weight:600;box-shadow:0 18px 40px -14px rgba(9,30,54,.6);z-index:99;transition:transform .45s var(--ease);display:flex;align-items:center;gap:10px}
.toast.show{transform:translateX(-50%) translateY(0)}.toast svg{width:18px;height:18px;stroke:var(--lime);fill:none;stroke-width:2.4;stroke-linecap:round;stroke-linejoin:round}
@media(max-width:980px){.hero{grid-template-columns:1fr}.features{grid-template-columns:repeat(2,1fr)}.two{grid-template-columns:1fr}.rev-grid{grid-template-columns:1fr}.foot-in{grid-template-columns:1fr}.stage{min-height:340px}}
@media(max-width:560px){.shell{padding:16px 14px 44px}.gallery{flex-direction:column-reverse}.thumbs{flex-direction:row}.info{padding:24px 20px}.ptitle{font-size:26px}}
</style></head><body>
<div class="shell">
  <div class="topbar">
    <a class="back" href="javascript:window.close()"><svg viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg> Back to Collection</a>
    <div class="crumb">Collection &middot; <b>${p.badge}</b> &middot; ${p.name}</div>
    <div class="wishbtn" id="wishBtn" onclick="toggleWish()"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.6-9.3-9A4.6 4.6 0 0 1 12 6.5 4.6 4.6 0 0 1 21.3 11C19 15.4 12 20 12 20z"/></svg><span id="wishLabel">Add to Wishlist</span></div>
  </div>
  <div class="card hero">
    <div class="gallery">
      <div class="thumbs">${thumbs4.map((g,i)=>{const pIdx=(hasPatterns&&i>0)?i-1:-1;const label=hasPatterns?(i===0?'main shot':patternNames[i-1]):('variant '+(i+1));return `<img src="${IMGF(g,200)}" class="${i===0?'active':''}" alt="${p.name} ${label}" onclick="setMain(this,'${IMGF(g,1000)}',${pIdx})" onerror="this.style.display='none'">`;}).join('')}</div>
      <div class="stage" id="stage" onclick="toggleZoom()" onmousemove="zoomMove(event)" onmouseleave="zoomOut()">
        <span class="badge">${p.badge} Grade</span>
        <img id="mainImg" src="${IMGF(p.img,1000)}" alt="${p.name}">
        <span class="hint">Click to zoom</span>
      </div>
    </div>
    <div class="info">
      <span class="kick">${p.fabric}</span>
      <h1 class="ptitle">${p.name}</h1>
      <div class="rating"><span class="stars">${star.repeat(5)}</span> ${p.rating} &middot; 128 verified reviews</div>
      ${priceBlock}
      <p class="desc">A premium ${p.badge.toLowerCase()}-grade textile engineered for heavy institutional use${p.tc&&p.tc!=='—'?` at ${p.tc}`:''}. Built for durability, comfort and repeated industrial laundering.</p>
      ${hasPatterns ? `
      <div class="lbl">Pattern <span class="sel-name" id="colName">${patternNames[0]}</span></div>
      <div class="swatches" id="sw">${patternNames.map((n,i)=>`<div class="sw pattern ${i===0?'sel':''}" style="background-image:url('${IMGF(patternImgs[i],120)}')" onclick="pickColor(${i})" title="${n}"></div>`).join('')}</div>
      ` : ''}
      <div class="lbl">Size <span class="sel-name" id="sizeName">${sizes[2]}</span></div>
      <div class="sizes" id="sz">${sizes.map((s,i)=>`<div class="size ${i===2?'sel':''}" onclick="pickSize(${i})">${s}</div>`).join('')}</div>
      <div class="lbl">Quantity</div>
      <div class="buy">
        <div class="qty"><button onclick="qd(-1)">&minus;</button><span id="qn">1</span><button onclick="qd(1)">+</button></div>
        <button class="btn btn-primary" id="addBtn" onclick="addCart()"><svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg> Add to Enquiry</button>
      </div>
      
      <div class="trust"><div><svg viewBox="0 0 24 24"><path d="M12 2.5l7.5 3.2v5.3c0 4.7-3.2 7.6-7.5 9.5-4.3-1.9-7.5-4.8-7.5-9.5V5.7z"/><path d="M9 12l2 2 4-4"/></svg> GST Invoiced</div><div><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Industrial-wash durable</div><div><svg viewBox="0 0 24 24"><path d="M3 7h13v10H3zM16 10h4l3 3v4h-7z"/></svg> Pan-TN delivery</div></div>
    </div>
  </div>
  <div class="features">${features.map(f=>`<div class="feat"><div class="fic"><svg viewBox="0 0 24 24">${featSVG[f[0]]}</svg></div><h4>${f[1]}</h4><p>${f[2]}</p></div>`).join('')}</div>
  <div class="two">
    <div class="card sec"><h3>Product Description</h3><p style="font-size:14px">The ${p.name} is made for hospitals, hotels and institutions that demand reliability at scale. Its ${p.fabric.toLowerCase()} construction, colour-fast dyeing and reinforced stitching withstand repeated high-temperature washing without losing shape or softness.</p>
      <ul class="checks"><li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> ${[p.tc!=='—'?p.tc:'',p.size,p.fabric].filter(Boolean).join(' &middot; ')}</li><li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Colour-fast and srink-resistant</li><li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Industrial-wash durable up to 200+ cycles</li><li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Available in bulk with custom branding</li></ul></div>
    <div class="card sec"><h3>Specifications</h3>
      <div class="dim"><span>Category</span><span class="v">${p.badge}</span></div>
      <div class="dim"><span>Fabric</span><span class="v">${p.fabric}</span></div>
      ${p.tc!=='—'?`<div class="dim"><span>Thread Count</span><span class="v">${p.tc}</span></div>`:''}
      <div class="dim"><span>Size</span><span class="v">${p.size}</span></div>
      <div class="dim"><span>Colour Options</span><span class="v">${p.color}</span></div>
      <div class="dim"><span>Minimum Order</span><span class="v">${p.enq?'On request':'1 pc (retail)'}</span></div>
      <div class="dim"><span>Lead Time</span><span class="v">7–10 days</span></div></div>
  </div>
  <div class="card reviews"><h3>Customer Reviews</h3>
    <div class="rev-grid">${reviews.map(r=>`<div class="rev"><div class="top"><div class="av">${r[0][0]}</div><div><div class="nm">${r[0]}</div><div class="vb"><svg viewBox="0 0 24 24" fill="none" stroke="#388E3C" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg> Verified Buyer</div></div></div><div class="rs">${star.repeat(5)}</div><p>${r[2]}</p><div class="when">${r[1]}</div></div>`).join('')}</div></div>
  <div class="related"><h3>You May Also Like</h3>
    <div class="rel-wrap">
      <button class="rel-arrow prev" id="relPrev" onclick="relScroll(-1)" aria-label="Previous"><svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg></button>
      <div class="rel-grid" id="relGrid">${related.map(r=>{const rp=r.enq?'On enquiry':`${r.from?'':''}`;return `<div class="rel" onclick="openRelated(${r.id})"><div class="ri"><img src="${IMGF(r.img,400)}" onerror="this.style.opacity=0"></div><div class="b"><div class="nm">${r.name}</div><div class="pr">${rp}</div></div></div>`;}).join('')}</div>
      <button class="rel-arrow next" id="relNext" onclick="relScroll(1)" aria-label="Next"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></button>
    </div></div>
</div>
<footer><div class="foot-in">
  <div class="foot-brand"><div class="fn">SriShakthi Tex <span>&middot; Karur</span></div><p>Premium hospital &amp; hotel textile solutions. Bulk supply made simple, direct from the manufacturer in Karur since 2018.</p>
    <div class="foot-soc"><a href="https://www.instagram.com/_sri_shakthi_tex_/" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="#fff" stroke="none"/></svg></a><a href="https://wa.me/9894624706" target="_blank" rel="noopener" aria-label="WhatsApp"><svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2z"/></svg></a><a href="mailto:srishakthitexkarur@gmail.com" target="_blank" rel="noopener" aria-label="Email"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></a></div></div>
  <div class="foot-col"><h4>Explore</h4><a href="javascript:window.close()">Back to Collection</a><a href="javascript:openRelated(${related[0]?related[0].id:id})">Browse Products</a></div>
