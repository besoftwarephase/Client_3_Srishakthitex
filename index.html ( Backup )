/* ============================================================
   SRISHAKTHI TEX · DESIGN TOKENS  (from case study v1.0)
   ============================================================ */
:root{
  /* brand */
  --navy:#0D2B4E;        /* primary / structure */
  --navy-900:#091E36;    /* deep ground / footer */
  --navy-700:#0D2B4E;
  --teal:#1B6CA8;        /* links · focus */
  --green:#4CAF50;       /* brand accent / success */
  --green-700:#388E3C;   /* accessible green / button */
  --green-800:#2E7D32;   /* pressed */
  --lime:#8BC34A;        /* tags · highlights */
  --yellow:#F5C842;      /* secondary CTA · offers */
  --coral:#F47B5C;       /* discount · wishlist */
  /* neutrals */
  --gray-50:#F8F9FA;     /* canvas */
  --white:#FFFFFF;
  --gray-100:#E9ECEF;    /* borders */
  --gray-200:#dfe3e8;
  /* text */
  --t-head:#091E36;
  --t-sub:#0D2B4E;
  --t-body:#343A40;
  --t-mut:#6C757D;
  --t-dis:#ADB5BD;
  /* navy tints */
  --navy-50:#E8EEF5;
  --navy-100:#C5D5E8;
  --navy-200:#8AAECF;
  /* spacing scale (8pt) */
  --s-xs:4px; --s-sm:8px; --s-12:12px; --s-md:16px; --s-lg:24px;
  --s-xl:32px; --s-2xl:48px; --s-3xl:64px; --s-4xl:96px;
  /* radii */
  --r-sm:10px; --r-md:16px; --r-lg:22px; --r-xl:30px; --r-pill:999px;
  /* shadow */
  --sh-sm:0 4px 14px -6px rgba(9,30,54,.18);
  --sh-md:0 18px 44px -22px rgba(9,30,54,.28);
  --sh-lg:0 38px 80px -34px rgba(9,30,54,.42);
  --glass:rgba(255,255,255,.72);
  --ease:cubic-bezier(.22,.61,.36,1);
  --maxw:1240px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden;scroll-padding-top:84px}
body{
  font-family:'Inter',system-ui,sans-serif;
