.modal-info .kicker{display:inline-block;color:var(--green-700);font-weight:700;font-size:11px;letter-spacing:.07em;text-transform:uppercase;margin-bottom:8px}
.modal-info .mprice{display:flex;align-items:baseline;gap:10px;margin:6px 0 14px}
.modal-info .mprice .from{font-size:13px;color:var(--t-mut)}
.modal-info .mprice .now{font-family:'Fraunces';font-weight:700;font-size:26px;color:var(--t-head)}
.modal-info .mprice .was{color:var(--t-mut);text-decoration:line-through;font-size:15px}
.modal-info .mprice .off{background:var(--coral);color:#fff;font-size:11px;font-weight:700;padding:3px 8px;border-radius:6px}
