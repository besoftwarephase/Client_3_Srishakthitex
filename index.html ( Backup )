.facet-sel select{appearance:none;-webkit-appearance:none;height:40px;padding:0 36px 0 15px;border:1.5px solid var(--gray-100);border-radius:var(--r-pill);background:#fff;font-family:'Inter';font-size:13.5px;color:var(--t-head);cursor:pointer;transition:.2s var(--ease);min-width:150px}
