/* layout helpers */
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}
.section{padding:var(--s-4xl) 0;position:relative}
@media(max-width:768px){.section{padding:var(--s-3xl) 0}}

/* eyebrow */
