.modal-info .mdesc{font-size:13.5px;color:var(--t-body);line-height:1.55;margin-bottom:16px}
.opt-lbl{font-size:11px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--t-mut);margin:0 0 9px}
