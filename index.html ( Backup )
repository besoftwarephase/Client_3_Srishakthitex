.filter-lbl{display:inline-flex;align-items:center;gap:7px;font-size:12.5px;font-weight:600;color:var(--t-mut);white-space:nowrap}
.filter-lbl i{width:16px;height:16px}
.prod-count{font-size:13px;color:var(--t-mut);white-space:nowrap;margin:0 0 20px}
