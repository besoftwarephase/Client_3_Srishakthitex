.foot-map i{width:15px;height:15px}

/* ============================================================
   ENQUIRY DRAWER + OVERLAY
   ============================================================ */
#overlay{position:fixed;inset:0;background:rgba(9,30,54,.55);backdrop-filter:blur(2px);z-index:90;opacity:0;visibility:hidden;transition:opacity .35s,visibility .35s}
#overlay.show{opacity:1;visibility:visible}
#drawer{
  position:fixed;top:0;right:0;height:100%;width:400px;max-width:92vw;background:#fff;z-index:95;
  transform:translateX(100%);transition:transform .42s var(--ease);display:flex;flex-direction:column;box-shadow:var(--sh-lg);
}
#drawer.open{transform:translateX(0)}
.dr-head{padding:22px 22px 16px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between;gap:12px}
.dr-head h3{font-size:19px;font-weight:600;flex:1}
.dr-close{width:38px;height:38px;border-radius:50%;background:var(--gray-50);color:var(--navy);display:flex;align-items:center;justify-content:center;transition:background .2s}
