function buildEnquiryText(f) {
  let t = `*NEW ORDER ENQUIRY – SRI SHAKTHI TEX*\n\n`;

  t += `*Customer Details*\n`;
  t += `• Name: ${f.name || '-'}\n`;
  t += `• Phone: ${f.phone || '-'}\n`;

  if (f.email) t += `• Email: ${f.email}\n`;
  if (f.industry) t += `• Industry: ${f.industry}\n`;

  if (enquiryItems.length) {
    t += `\n*Products Requested*\n`;

    enquiryItems.forEach((e, i) => {
      const p = byId(e.id);
      if (!p) return;

      t += `\n${i + 1}. *${p.name}*\n`;

      if (p.tc && p.tc !== '—')
        t += `   • Thread Count: ${p.tc}\n`;

      if (p.size)
        t += `   • Size: ${p.size}\n`;

      t += `   • Quantity: ${e.qty}\n`;
    });
  }

  if (f.msg) {
    t += `\n*Additional Requirements*\n${f.msg}\n`;
  }

  t += `\nKindly provide product details, pricing, and delivery information.\n\n`;
  t += `Thank you.`;

  return t;
}
