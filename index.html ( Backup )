let filterColor = 'all';
let filterSize = 'all';
function buildFacets(){
  const colors=[...new Set(PRODUCTS.map(p=>p.color).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
  const sizes=[...new Set(PRODUCTS.map(p=>p.size).filter(s=>s&&s!=='—'))].sort((a,b)=>a.localeCompare(b));
  const cs=document.getElementById('f-color'), ss=document.getElementById('f-size');
  if(cs) cs.innerHTML='<option value="all">All colours</option>'+colors.map(c=>`<option value="${c}">${c}</option>`).join('');
  if(ss) ss.innerHTML='<option value="all">All sizes</option>'+sizes.map(s=>`<option value="${s}">${s}</option>`).join('');
}
function onFacet(){
  const c=document.getElementById('f-color'), s=document.getElementById('f-size');
  filterColor=c?c.value:'all'; filterSize=s?s.value:'all';
  renderProducts();
}
function clearFacets(){
  filterColor='all'; filterSize='all'; currentFilter='all'; searchTerm='';
  const c=document.getElementById('f-color'), s=document.getElementById('f-size'), q=document.getElementById('search');
  if(c)c.value='all'; if(s)s.value='all'; if(q)q.value='';
  document.querySelectorAll('.filter-tab').forEach(t=>t.classList.toggle('active', t.dataset.cat==='all'));
  renderProducts();
}

function loadState(){
  try{
    const r = JSON.parse(localStorage.getItem(STORE_KEY)||'null');
    if(r && r.exp && r.exp > Date.now()){
      enquiryItems  = Array.isArray(r.enquiryItems)  ? r.enquiryItems.filter(e=>byId(e.id))  : [];
      wishlistItems = Array.isArray(r.wishlistItems) ? r.wishlistItems.filter(id=>byId(id)) : [];
    } else { localStorage.removeItem(STORE_KEY); }
  }catch(e){ /* ignore corrupt */ }
}
function saveState(){
  try{ localStorage.setItem(STORE_KEY, JSON.stringify({enquiryItems, wishlistItems, exp: Date.now()+STORE_TTL})); }catch(e){}
}
/* re-pull when returning from a product tab that changed the cart */
function reSync(){
  const before = JSON.stringify([enquiryItems,wishlistItems]);
  loadState();
  if(JSON.stringify([enquiryItems,wishlistItems])!==before){
    renderProducts(); renderEnquiry(); updateBadges();
  }
}
document.addEventListener('visibilitychange',()=>{ if(!document.hidden) reSync(); });
window.addEventListener('focus', reSync);

const byId = id => PRODUCTS.find(p=>p.id===id);
const priceLabel = p => p.enq ? '<span class="enq">On enquiry</span>'
  : `${p.from?'<span class="from"></span>':''}<span class="now tnum"></span>${p.mrp?`<span class="mrp tnum"></span>`:''}`;
const starsHTML = (n=5,full=5)=>{let s='';for(let i=1;i<=5;i++){s+=`<i data-lucide="star"${i<=Math.round(full)?'':' style="fill:#f5c842;opacity:.35"'}></i>`;}return s;};
function starSvg(color){
  let p='';
  for(let i=0;i<5;i++){ p+=`<path transform="translate(${i*20},0)" fill="${color}" d="M10 1.6l2.47 5.01 5.53.8-4 3.9.94 5.51L10 14.23 5.06 16.82 6 11.31l-4-3.9 5.53-.8z"/>`; }
  return `<svg viewBox="0 0 100 20" preserveAspectRatio="xMinYMid meet" xmlns="http://www.w3.org/2000/svg">${p}</svg>`;
}
function googleStars(r){
  const pct = Math.max(0,Math.min(100,(r/5)*100));
  return `<span class="g-stars" aria-label="${r} out of 5 stars"><span class="g-base">${starSvg('#dadce0')}</span><span class="g-fill" style="width:${pct}%">${starSvg('#FBBC04')}</span></span>`;
}

/* ============================================================
   ICONS refresh
   ============================================================ */
function icons(){ if(window.lucide) lucide.createIcons(); }

/* ============================================================
   PRODUCTS RENDER + FILTER + SEARCH
   ============================================================ */
function visibleProducts(){
  return PRODUCTS.filter(p=>{
    const catOk = currentFilter==='all' || p.cat===currentFilter;
    const colorOk = filterColor==='all' || p.color===filterColor;
    const sizeOk = filterSize==='all' || p.size===filterSize;
    const q = searchTerm.trim().toLowerCase();
    const searchOk = !q || [p.name,p.tc,p.size,p.color,p.fabric,p.badge].join(' ').toLowerCase().includes(q);
    return catOk && colorOk && sizeOk && searchOk;
  });
}
function renderProducts(){
  const grid = document.getElementById('prod-grid');
  const list = visibleProducts();
  const cnt = document.getElementById('prod-count-n');
  if(cnt) cnt.textContent = list.length;
  if(!list.length){
    grid.innerHTML = `<div class="empty-state"><i data-lucide="search-x"></i><h3>No products found</h3><p>Try a different filter or search term — or send us an enquiry and we'll source it.</p></div>`;
    icons(); return;
  }
  grid.innerHTML = list.map(p=>{
    const wished = wishlistItems.includes(p.id);
    const disc = p.mrp ? Math.round((1-p.price/p.mrp)*100) : 0;
    return `<article class="pcard" onclick="openProduct(${p.id})" title="View full details — opens in a new tab">
      <div class="pthumb">
        <img src="${IMG(p.img)}" alt="${p.name}" loading="lazy" onerror="imgErr(this)">
        ${disc?`<span class="pdisc-badge">-${disc}%</span>`:`<span class="pcat-badge">${p.badge}</span>`}
        <button class="pwish ${wished?'on':''}" id="w-${p.id}" aria-label="Save ${p.name} to wishlist" aria-pressed="${wished}" onclick="event.stopPropagation();toggleWish(${p.id})"><i data-lucide="heart"></i></button>
        <button class="pquick" onclick="event.stopPropagation();openModal(${p.id})"><i data-lucide="eye"></i>Quick View</button>
      </div>
      <div class="pbody">
        <h3>${p.name}</h3>
        <div class="pspec">
          ${p.tc!=='—'?`<span><i data-lucide="layers"></i>${p.tc}</span>`:''}
          <span><i data-lucide="ruler"></i>${p.size}</span>
        </div>
        <div class="prating"><span class="g-rate">${p.rating}</span>${googleStars(p.rating)}</div>
        <div class="pprice">${priceLabel(p)}</div>
        <button class="btn btn-primary btn-sm padd btn-block" onclick="event.stopPropagation();addToEnquiry(${p.id})"><i data-lucide="plus"></i>Add to Enquiry</button>
      </div>
    </article>`;
  }).join('');
  icons();
}
function setFilter(btn){
  document.querySelectorAll('.filter-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  currentFilter = btn.dataset.cat;
  renderProducts();
}
function filterTo(cat){
  currentFilter = cat;
  document.querySelectorAll('.filter-tab').forEach(t=>t.classList.toggle('active', t.dataset.cat===cat));
  renderProducts();
  document.getElementById('products').scrollIntoView({behavior:'smooth'});
}
function onSearch(){ searchTerm = document.getElementById('search').value; renderProducts(); }
function focusSearch(){ document.getElementById('products').scrollIntoView({behavior:'smooth'}); setTimeout(()=>document.getElementById('search').focus(),500); }

/* ============================================================
   WISHLIST
   ============================================================ */
function toggleWish(id){
  const i = wishlistItems.indexOf(id);
  if(i===-1){ wishlistItems.push(id); toast(` saved to wishlist`); }
  else { wishlistItems.splice(i,1); }
  const btn = document.getElementById('w-'+id);
  if(btn){ const on = wishlistItems.includes(id); btn.classList.toggle('on',on); btn.setAttribute('aria-pressed',on); }
  saveState(); updateBadges();
}
function openWishlist(){
  if(!wishlistItems.length){ toast('Your wishlist is empty — tap the heart on any product'); return; }
  currentFilter='all'; searchTerm=''; document.getElementById('search').value='';
  document.querySelectorAll('.filter-tab').forEach(t=>t.classList.toggle('active',t.dataset.cat==='all'));
  const grid=document.getElementById('prod-grid');
  const list=PRODUCTS.filter(p=>wishlistItems.includes(p.id));
  grid.innerHTML=list.map(p=>{
    const disc=p.mrp?Math.round((1-p.price/p.mrp)*100):0;
    return `<article class="pcard" onclick="openProduct(${p.id})" title="View full details — opens in a new tab">
      <div class="pthumb"><img src="${IMG(p.img)}" alt="${p.name}" loading="lazy" onerror="imgErr(this)">
      ${disc?`<span class="pdisc-badge">-${disc}%</span>`:`<span class="pcat-badge">${p.badge}</span>`}
      <button class="pwish on" id="w-${p.id}" aria-pressed="true" onclick="event.stopPropagation();toggleWish(${p.id});openWishlist()"><i data-lucide="heart"></i></button>
      <button class="pquick" onclick="event.stopPropagation();openModal(${p.id})"><i data-lucide="eye"></i>Quick View</button></div>
      <div class="pbody"><h3>${p.name}</h3>
      <div class="pspec">${p.tc!=='—'?`<span><i data-lucide="layers"></i>${p.tc}</span>`:''}<span><i data-lucide="ruler"></i>${p.size}</span></div>
      <div class="prating"><span class="stars">${starsHTML(5,p.rating)}</span>${p.rating}</div>
      <div class="pprice">${priceLabel(p)}</div>
      <button class="btn btn-primary btn-sm padd btn-block" onclick="event.stopPropagation();addToEnquiry(${p.id})"><i data-lucide="plus"></i>Add to Enquiry</button></div></article>`;
  }).join('');
  icons();
  document.getElementById('products').scrollIntoView({behavior:'smooth'});
  toast(`Showing ${list.length} wishlisted item${list.length>1?'s':''}`);
}

/* ============================================================
   ENQUIRY (cart)
   ============================================================ */
function addToEnquiry(id, qty=1){
  const item = enquiryItems.find(e=>e.id===id);
  if(item) item.qty += qty; else enquiryItems.push({id,qty});
  toast(`added to enquiry`);
  saveState(); updateBadges(); renderEnquiry();
}
function changeQty(id, delta){
  const item = enquiryItems.find(e=>e.id===id); if(!item) return;
  item.qty = Math.max(1, item.qty+delta);
  saveState(); updateBadges(); renderEnquiry();
}
function setQtyVal(id,val){
  const item = enquiryItems.find(e=>e.id===id); if(!item) return;
  item.qty = Math.max(1, parseInt(val)||1);
  saveState(); updateBadges(); renderEnquiry();
}
function removeEnquiry(id){
  enquiryItems = enquiryItems.filter(e=>e.id!==id);
  saveState(); updateBadges(); renderEnquiry(); toast('Item removed from enquiry');
}
function updateBadges(){
  const c = enquiryItems.reduce((a,e)=>a+e.qty,0);
  const cb=document.getElementById('cart-badge'); cb.textContent=c; cb.classList.toggle('show',c>0);
  const w=wishlistItems.length;
  const wb=document.getElementById('wish-badge'); wb.textContent=w; wb.classList.toggle('show',w>0);
}
function renderEnquiry(){
  // section cart table
  const t=document.getElementById('ct-rows');
  if(t){
    if(!enquiryItems.length){
      t.innerHTML=`<div class="ct-empty"><span>No products added yet. Browse the collection and tap “Add to Enquiry”.</span></div>`;
    } else {
      t.innerHTML=enquiryItems.map(e=>{const p=byId(e.id);return `
        <div class="ct-row">
          <div class="ct-prod"><img src="${IMG(p.img,120)}" alt="" loading="lazy" onerror="imgErr(this)"><div><div class="en">${p.name}</div><div class="eb">${p.badge}</div></div></div>
          <div class="ct-spec">${[p.tc!=='—'?p.tc:'',p.size].filter(Boolean).join(' · ')}</div>
          <div class="ct-qty"><div class="qty-step"><button aria-label="Decrease" onclick="changeQty(${p.id},-1)">−</button><input type="text" value="${e.qty}" aria-label="Quantity" onchange="setQtyVal(${p.id},this.value)"><button aria-label="Increase" onclick="changeQty(${p.id},1)">+</button></div></div>
          <div class="ct-act"><button class="erm" aria-label="Remove ${p.name}" onclick="removeEnquiry(${p.id})"><i data-lucide="trash-2"></i></button></div>
        </div>`;}).join('');
    }
  }
  // drawer
  const d=document.getElementById('dr-body');
  if(!enquiryItems.length){
    d.innerHTML=`<div class="enq-empty">No items yet.<br>Browse products and tap "Add to Enquiry".</div>`;
    document.getElementById('dr-count').textContent='No items yet';
  } else {
    d.innerHTML=`<div class="etable">`+enquiryItems.map(e=>{const p=byId(e.id);return `
      <div class="erow">
        <img src="${IMG(p.img,120)}" alt="" loading="lazy" onerror="imgErr(this)">
        <div><div class="en">${p.name}</div><div class="es">${p.size}</div></div>
        <div class="qty-step"><button onclick="changeQty(${p.id},-1)">−</button><input type="text" value="${e.qty}" onchange="setQtyVal(${p.id},this.value)"><button onclick="changeQty(${p.id},1)">+</button></div>
        <button class="erm" aria-label="Remove" onclick="removeEnquiry(${p.id})"><i data-lucide="trash-2"></i></button>
      </div>`;}).join('')+`</div>`;
    const total=enquiryItems.reduce((a,e)=>a+e.qty,0);
    document.getElementById('dr-count').textContent=`${enquiryItems.length} product${enquiryItems.length>1?'s':''} · ${total} unit${total>1?'s':''}`;
  }
  icons();
}
function openDrawer(){ document.getElementById('drawer').classList.add('open'); document.getElementById('overlay').classList.add('show'); document.body.style.overflow='hidden'; }
function closeDrawer(){ document.getElementById('drawer').classList.remove('open'); document.getElementById('overlay').classList.remove('show'); document.body.style.overflow=''; }
function goToForm(){ closeDrawer(); document.getElementById('enquiry').scrollIntoView({behavior:'smooth'}); }

/* ============================================================
   QUICK VIEW MODAL
   ============================================================ */
let modalQtyVal=1, modalId=null, lastFocus=null, galImgs=[], galIdx=0, mPatternNames=[], mPatternIdx=0, mSize=1;
function openModal(id){
  const p=byId(id); modalId=id; modalQtyVal=1; lastFocus=document.activeElement;
  const hasPatterns = !!(p.patterns && Object.keys(p.patterns).length);
  mPatternNames = hasPatterns ? Object.keys(p.patterns) : [];
  galImgs = hasPatterns ? [p.img, ...Object.values(p.patterns)] : productImgs(p);
  galIdx=0; mPatternIdx=0; mSize=1;
  const disc=p.mrp?Math.round((1-p.price/p.mrp)*100):0;
  const wished=wishlistItems.includes(id);
  const sizes=['S','M','L','XL','2XL'];
  const priceHTML = p.enq
    ? '<span class="enq">Price on enquiry</span>'
    : `${p.from?'<span class="from"></span>':''}<span class="now tnum"></span>${p.mrp?`<span class="was tnum"></span><span class="off">${disc}% OFF</span>`:''}`;
  document.getElementById('modal-card').innerHTML=`
    <button class="modal-close" aria-label="Close" onclick="closeModal()"><i data-lucide="x"></i></button>
    <div class="modal-grid">
      <div class="modal-gallery">
        <div class="mg-main" id="mg-main" onclick="mgZoom()" onmousemove="mgMove(event)" onmouseleave="mgOut()">
          <span class="mbadge">${p.badge}</span>
          <img id="mg-img" src="${IMG(galImgs[0],900)}" alt="${p.name}" onerror="imgErr(this)">
          <button class="mg-nav prev" aria-label="Previous" onclick="event.stopPropagation();galNav(-1)"><i data-lucide="chevron-left"></i></button>
          <button class="mg-nav next" aria-label="Next" onclick="event.stopPropagation();galNav(1)"><i data-lucide="chevron-right"></i></button>
          <span class="mg-hint"><i data-lucide="search"></i>Hover to zoom</span>
        </div>
        <div class="mg-thumbs" id="mg-thumbs">${galImgs.map((g,i)=>`<img src="${IMG(g,160)}" class="${i===0?'active':''}" onclick="galSet(${i})" onerror="this.style.display='none'">`).join('')}</div>
      </div>
      <div class="modal-info">
        <span class="kicker">${p.badge} · ${p.fabric}</span>
        <h2>${p.name}</h2>
        <div class="mrate"><span class="stars">${starsHTML(5,p.rating)}</span>${p.rating} · 128 reviews</div>
        <div class="mprice">${priceHTML}</div>
        <p class="mdesc">A premium ${p.badge.toLowerCase()}-grade textile${p.tc!=='—'?` at ${p.tc}`:''}, engineered for institutional use — durable, comfortable and built for repeated industrial laundering.</p>
        ${hasPatterns ? `
        <div class="opt-lbl">Pattern <b id="m-cname">${mPatternNames[0]}</b></div>
        <div class="chips" id="m-colors">${mPatternNames.map((n,i)=>`<button class="swatch pattern ${i===0?'sel':''}" style="background-image:url('${IMG(p.patterns[n],120)}')" title="${n}" onclick="mPickColor(${i},'${n}')"></button>`).join('')}</div>
        ` : ''}
        <div class="opt-lbl">Size <b id="m-sname">${sizes[1]}</b></div>
        <div class="chips" id="m-sizes">${sizes.map((s,i)=>`<button class="chip-size ${i===1?'sel':''}" onclick="mPickSize(${i},'${s}')">${s}</button>`).join('')}</div>
        <div class="modal-actions">
          <div class="qty-step"><button aria-label="Decrease" onclick="modalQty(-1)">−</button><input type="text" id="m-qty" value="1" aria-label="Quantity" onchange="modalQtySet(this.value)"><button aria-label="Increase" onclick="modalQty(1)">+</button></div>
          <button class="btn btn-primary" onclick="modalAdd()"><i data-lucide="plus"></i>Add to Enquiry</button>
          <button class="m-wish ${wished?'on':''}" id="m-wish" aria-label="Wishlist" onclick="toggleWishModal(${id})"><i data-lucide="heart"></i></button>
        </div>
        <a class="modal-link" href="javascript:void(0)" onclick="openProduct(${id});closeModal()">View full product details<i data-lucide="arrow-right"></i></a>
        <div class="mtrust"><span><i data-lucide="truck"></i>Pan-TN delivery</span><span><i data-lucide="shield-check"></i>GST invoice</span><span><i data-lucide="badge-check"></i>Custom branding</span></div>
      </div>
    </div>`;
  const m=document.getElementById('modal'); m.classList.add('show'); document.body.style.overflow='hidden';
  icons(); setTimeout(()=>m.querySelector('.modal-close').focus(),50);
}
function galSet(i){
  galIdx=i; document.getElementById('mg-img').src=IMG(galImgs[i],900);
  document.querySelectorAll('#mg-thumbs img').forEach((t,x)=>t.classList.toggle('active',x===i));
  /* keep the Pattern swatch in sync when a pattern thumb is picked directly */
  if(mPatternNames.length && i>=1){
    mPatternIdx=i-1;
    document.querySelectorAll('#m-colors .swatch').forEach((s,x)=>s.classList.toggle('sel',x===mPatternIdx));
    const cn=document.getElementById('m-cname'); if(cn) cn.textContent=mPatternNames[mPatternIdx];
  }
}
function galNav(d){ galSet((galIdx+d+galImgs.length)%galImgs.length); }
function mgZoom(){ document.getElementById('mg-main').classList.toggle('zoom'); }
function mgMove(e){ const s=document.getElementById('mg-main'); if(!s.classList.contains('zoom'))return; const r=s.getBoundingClientRect(); document.getElementById('mg-img').style.transformOrigin=((e.clientX-r.left)/r.width*100)+'% '+((e.clientY-r.top)/r.height*100)+'%'; }
function mgOut(){ document.getElementById('mg-main').classList.remove('zoom'); }
function mPickColor(i,name){
  mPatternIdx=i;
  document.querySelectorAll('#m-colors .swatch').forEach((s,x)=>s.classList.toggle('sel',x===i));
  document.getElementById('m-cname').textContent=name;
  /* clicking a Pattern swatch auto-highlights & shows its matching gallery image (thumb 0 is the default shot, patterns start at thumb 1) */
  galSet(i+1);
}
function mPickSize(i,name){ mSize=i; document.querySelectorAll('#m-sizes .chip-size').forEach((s,x)=>s.classList.toggle('sel',x===i)); document.getElementById('m-sname').textContent=name; }
function toggleWishModal(id){ toggleWish(id); const b=document.getElementById('m-wish'); if(b)b.classList.toggle('on',wishlistItems.includes(id)); }
function closeModal(){ document.getElementById('modal').classList.remove('show'); document.body.style.overflow=''; if(lastFocus)lastFocus.focus(); }
function modalQty(d){ modalQtyVal=Math.max(1,modalQtyVal+d); document.getElementById('m-qty').value=modalQtyVal; }
function modalQtySet(v){ modalQtyVal=Math.max(1,parseInt(v)||1); document.getElementById('m-qty').value=modalQtyVal; }
function modalAdd(){ addToEnquiry(modalId,modalQtyVal); closeModal(); }

/* ============================================================
   FULL PRODUCT DETAIL PAGE — opens in a new tab (Blob)
   Shares the same localStorage cart key as the main page.
   ============================================================ */
