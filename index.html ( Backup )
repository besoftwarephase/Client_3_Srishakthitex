  const IMGF=(i,w)=> /^https?:\/\//.test(i) ? `${i}${i.includes('?')?'&':'?'}w=${w}` : (i.includes('/') ? i : `https://images.unsplash.com/photo-${i}?auto=format&fit=crop&w=${w}&q=72`);

