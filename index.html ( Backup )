  `).join('');

  lucide.createIcons();

  // Ensure first accordion is open
  const firstBody = document.querySelector('#acc-0 .acc-body');
  if (firstBody) {
    firstBody.style.maxHeight = firstBody.scrollHeight + 'px';
  }
}
function toggleAcc(i){
  const item=document.getElementById('acc-'+i);
  const isOpen=item.classList.contains('active');
  document.querySelectorAll('.acc-item').forEach(a=>{a.classList.remove('active');a.querySelector('.acc-body').style.maxHeight=null;a.querySelector('.acc-head').setAttribute('aria-expanded','false');});
  if(!isOpen){
    item.classList.add('active');
    const b=item.querySelector('.acc-body'); b.style.maxHeight=b.scrollHeight+'px';
    item.querySelector('.acc-head').setAttribute('aria-expanded','true');
  }
}

