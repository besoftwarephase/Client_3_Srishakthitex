.dr-body{flex:1;overflow-y:auto;padding:16px 22px;scrollbar-width: thin;}
.dr-foot{padding:18px 22px;border-top:1px solid var(--gray-100);background:var(--gray-50)}
.dr-count{font-size:13px;color:var(--t-mut);margin-bottom:12px}

/* ============================================================
   QUICK VIEW MODAL
   ============================================================ */
#modal{position:fixed;inset:0;z-index:100;display:none;align-items:center;justify-content:center;padding:20px}
#modal.show{display:flex}
#modal .mbg{position:absolute;inset:0;background:rgba(9,30,54,.6);backdrop-filter:blur(3px)}
.modal-card{position:relative;background:#fff;border-radius:var(--r-xl);max-width:880px;width:100%;max-height:90vh;overflow:auto;display:grid;grid-template-columns:1fr 1fr;box-shadow:var(--sh-lg);animation:pop .35s var(--ease)}
@keyframes pop{from{opacity:0;transform:scale(.96) translateY(10px)}to{opacity:1;transform:none}}
.modal-img{position:relative;background:var(--navy-50);min-height:380px}
.modal-img img{width:100%;height:100%;object-fit:cover}
.modal-img .mbadge{position:absolute;top:16px;left:16px;background:var(--lime);color:var(--navy);font-size:11px;font-weight:700;padding:5px 12px;border-radius:var(--r-pill)}
.modal-info{padding:32px;display:flex;flex-direction:column}
.modal-close{position:absolute;top:14px;right:14px;width:40px;height:40px;border-radius:50%;background:#fff;color:var(--navy);display:flex;align-items:center;justify-content:center;box-shadow:var(--sh-sm);z-index:3;transition:background .2s}
.modal-close:hover{background:var(--gray-50)}
.modal-info h2{font-size:26px;font-weight:700;margin-bottom:6px}
.modal-info .mrate{display:flex;align-items:center;gap:6px;color:var(--t-mut);font-size:13px;margin-bottom:16px}
.modal-info .mrate .stars{color:var(--yellow);display:flex}
.modal-info .mrate .stars i{width:15px;height:15px;fill:var(--yellow)}
.mspec-list{display:flex;flex-direction:column;gap:10px;margin:8px 0 18px;padding:18px;background:var(--gray-50);border-radius:var(--r-md)}
.mspec-list .row{display:flex;justify-content:space-between;font-size:13.5px}
.mspec-list .row .k{color:var(--t-mut)}
.mspec-list .row .v{color:var(--t-sub);font-weight:600}
.mprice{display:flex;align-items:baseline;gap:10px;margin-bottom:18px}
.mprice .now{font-family:'Fraunces';font-weight:700;font-size:30px;color:var(--t-head)}
.mprice .mrp{font-size:15px;color:var(--t-dis);text-decoration:line-through}
.mprice .enq{font-family:'Fraunces';font-weight:700;font-size:22px;color:var(--green-700)}
.mqty{display:flex;align-items:center;gap:14px;margin-bottom:18px}
.mqty span{font-size:13px;font-weight:600;color:var(--t-sub)}
.modal-actions{display:flex;gap:10px;margin-top:auto}
.mtrust{display:flex;gap:14px;margin-top:16px;flex-wrap:wrap}
.mtrust span{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;color:var(--t-mut);font-weight:500}
.mtrust i{width:14px;height:14px;color:var(--green-700)}

/* ============================================================
   TOAST
   ============================================================ */
#toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(120px);z-index:200;background:var(--navy);color:#fff;padding:14px 22px;border-radius:var(--r-pill);font-size:14px;box-shadow:var(--sh-lg);display:flex;align-items:center;gap:10px;transition:transform .4s var(--ease);max-width:90vw}
#toast.show{transform:translateX(-50%) translateY(0)}
#toast i{width:18px;height:18px;color:var(--lime)}
#toast b{color:var(--lime);font-weight:600}

/* ============================================================
   SCROLL REVEAL
   ============================================================ */
/* ============================================================
   ADDED COMPONENTS — hero parallax, modal gallery, enquiry panel,
   scrolling reviews + logos, search refinements
   ============================================================ */
/* Hero banner — changing parallax images */
.hero-bg{position:absolute;inset:-10% -6%;z-index:0;will-change:transform}
.hb-layer{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity 1.6s var(--ease);transform:translateX(0) scale(1.08);will-change:transform}
.hb-layer.on{opacity:1;animation:heroPan 18s ease-in-out infinite alternate}
.hero-bg-veil{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(9,30,54,.04) 0%,transparent 30%,rgba(9,30,54,.42) 100%)}
@keyframes heroPan{from{transform:translateX(-3.5%) scale(1.08)}to{transform:translateX(3.5%) scale(1.08)}}
@media(prefers-reduced-motion:reduce){.hero-bg{transform:none!important}.hb-layer{transition:none;animation:none}}

/* Search box redesign — minimal */
.search-box{position:relative;min-width:280px;flex:1;max-width:380px}
.search-box i{position:absolute;left:16px;top:50%;transform:translateY(-50%);width:18px;height:18px;color:var(--t-mut);pointer-events:none}
.search-box input{width:100%;height:46px;padding:0 16px 0 44px;border:1.5px solid var(--gray-100);border-radius:var(--r-pill);font-family:'Inter';font-size:14.5px;color:var(--t-head);background:var(--white);transition:.22s var(--ease)}
.search-box input::placeholder{color:var(--t-mut)}
.search-box input:focus{outline:none;border-color:var(--teal);box-shadow:0 0 0 4px rgba(27,108,168,.12)}

/* products toolbar */
#products{background:var(--white)}
